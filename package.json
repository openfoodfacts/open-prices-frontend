    "compressorjs": "^1.3.0",
    "exifreader": "^4.41.0",
    "html5-qrcode": "^2.3.8",
    "keycloak-js": "^26.2.4",
    "leaflet": "^1.9.4",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^4.7.1",
    "universal-cookie": "^7.2.2",
    "vega": "^5.33.0",
    "vega-embed": "^6.29.0",
    "vega-lite": "^5.23.0",
    "vue": "^3.5.40",
    "vue-i18n": "9.14.5",
